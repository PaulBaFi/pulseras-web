---
import { Image } from "astro:assets";
import logo from "/iconlogo.svg?url";

const currentYear = new Date().getFullYear();
---

<footer
  class="px-(--margin-mobile) md:px-(--margin-desktop) py-12 bg-[#1D242D] text-white"
>
  <div class="container mx-auto space-y-8">
    <div
      class="flex flex-col md:flex-row md:items-center md:justify-between gap-8 text-center md:text-left"
    >
      <div class="space-y-2 flex flex-col items-center md:items-start">
        <a href="/" class="inline-flex items-center gap-2">
          <Image
            class="brightness-0 invert saturate-100"
            src={logo}
            width={44}
            height={32}
            alt="Logo"
            loading="eager"
          />
          <span class="tracking-wider uppercase font-bold text-xl text-white">
            Pulseras
          </span>
        </a>

        <p class="text-sm text-slate-400">
          Pulseras caseras para contar tu historia
        </p>
      </div>

      <div class="space-y-3">
        <strong
          class="text-xs uppercase tracking-wider text-slate-500 font-bold block"
        >
          Navegación
        </strong>
        <nav
          class="flex flex-col md:flex-row gap-4 md:gap-8 items-center text-sm text-slate-300"
        >
          <a
            href="/#productos"
            class="hover:text-white transition-colors py-1 md:py-0"
          >
            Pulseras
          </a>
          <a
            href="/#nosotros"
            class="hover:text-white transition-colors py-1 md:py-0"
          >
            Nosotros
          </a>
          <a
            href="#soporte"
            class="hover:text-white transition-colors py-1 md:py-0"
          >
            Soporte
          </a>
        </nav>
      </div>
    </div>

    <hr class="border-slate-800" />

    <div class="text-slate-500 text-center text-xs md:text-sm">
      <p>© {currentYear} | Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
