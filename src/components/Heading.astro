---
interface Props {
  title: string;
  icon: any;
}

const { title, icon: Icon } = Astro.props;
---

<div class="flex items-center justify-center gap-3 w-fit">
  <div class="p-2.5 rounded-xl bg-slate-700 text-white">
    <Icon />
  </div>
  <h2 class="text-slate-700 text-3xl font-bold">{title}</h2>
</div>
