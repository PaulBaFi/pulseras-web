---
import Heading from "@/components/Heading.astro";
import { COLECCIONES, type Coleccion } from "@/lib/catalogo";
import Image from "astro/components/Image.astro";
import { MoveRight, Package } from "@lucide/astro";
---

<section class="px-(--margin-mobile) md:px-(--margin-desktop)">
  <div class="container mx-auto space-y-6">
    <Heading title="Colecciones" icon={Package} />

    <article class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        COLECCIONES.map((c: Coleccion) => (
          <div class="group rounded-xl border border-slate-200 p-2">
            <div class="mb-2 grid grid-cols-2 gap-2 grid-rows-2 aspect-4/3">
              <div class="bg-slate-50 w-full h-full overflow-hidden rounded-md row-span-2">
                <Image
                  src="/images/puls-001-1.png"
                  width={400}
                  height={300}
                  alt="Imagen de la colección"
                  loading="lazy"
                  class="object-center object-cover h-full"
                />
              </div>
              <div class="bg-slate-50 w-full h-full overflow-hidden rounded-md">
                <Image
                  src="/images/puls-002-1.png"
                  width={400}
                  height={300}
                  alt="Imagen de la colección"
                  loading="lazy"
                  class="object-center object-cover h-full"
                />
              </div>
              <div class="bg-slate-50 w-full h-full overflow-hidden rounded-md">
                <Image
                  src="/images/puls-002-2.png"
                  width={400}
                  height={300}
                  alt="Imagen de la colección"
                  loading="lazy"
                  class="object-center object-cover h-full"
                />
              </div>
            </div>

            <div class="text-slate-700 inline-flex items-center justify-between w-full gap-4 px-2">
              <strong class="text-lg">{c.nombre}</strong>
              <MoveRight
                size={20}
                stroke-width={2}
                class="-translate-x-2 group-hover:translate-x-0 transition-transform duration-150"
              />
            </div>
          </div>
        ))
      }
    </article>
  </div>
</section>
